        function loadHistory() {
            fetch('/api/analysis/history')
            .then(r => r.json())
            .then(data => {
                if (data.success && data.history.length > 0) {
                    const listEl = document.getElementById('historyList');
                    let html = '<table class="history-table"><thead><tr><th>ж—¶й—ҙ</th><th>жқҘжәҗ</th><th>иҜ„и®әж•?/th><th>жӯЈйқў</th><th>дёӯжҖ?/th><th>иҙҹйқў</th><th>ж“ҚдҪң</th></tr></thead><tbody>';
                    data.history.forEach(h => {
                        // еӨ„зҗҶжғ…ж„ҹж ҮзӯҫеҲҶеёғ
                        let pos = 0, neu = 0, neg = 0;
                        if (typeof h.sentiment_labels === 'object' && h.sentiment_labels !== null) {
                            // еҗҺз«ҜеӯҳеӮЁзҡ„жҳҜеҜ№иұЎж јејҸ {"0": 10, "1": 20, "2": 15}
                            pos = h.sentiment_labels['2'] || 0;
                            neu = h.sentiment_labels['1'] || 0;
                            neg = h.sentiment_labels['0'] || 0;
                        } else if (Array.isArray(h.sentiment_labels)) {
                            // е…је®№ж—§зҡ„ж•°з»„ж јејҸ
                            pos = h.sentiment_labels.filter(l => l === 2).length;
                            neu = h.sentiment_labels.filter(l => l === 1).length;
                            neg = h.sentiment_labels.filter(l => l === 0).length;
                        }
                        const date = new Date(h.created_at).toLocaleString('zh-CN');
                        // дјҳеҢ–жқҘжәҗзұ»еһӢжҳҫзӨә
                        let sourceText = 'жңӘзҹҘ';
                        switch(h.source_type) {
                            case 'deepseek':
                                sourceText = 'иҫ“е…ҘиҜ„и®ә';
                                break;
                            case 'uploaded':
                                sourceText = 'дёҠдј ж–ҮжЎЈ';
                                break;
                            case 'simulated':
                                sourceText = 'жЁЎжӢҹж•°жҚ®';
                                break;
                            case 'screenshot':
                                sourceText = 'жҲӘеӣҫ';
                                break;
                            default:
                                sourceText = h.source_type;
                        }
                        html += `<tr>
                            <td>${date}</td>
                            <td>${sourceText}</td>
                            <td>${h.comment_count}</td>
                            <td><span class="label-badge label-positive">${pos}</span></td>
                            <td><span class="label-badge label-neutral">${neu}</span></td>
                            <td><span class="label-badge label-negative">${neg}</span></td>
                            <td><a class="link-btn" onclick="viewHistoryDetail(${h.id})">жҹҘзңӢ</a></td>
                        </tr>`;
                    });
                    html += '</tbody></table>';
                    listEl.innerHTML = html;
                } else {
                    document.getElementById('historyList').innerHTML = '<p style="color: #666; text-align: center;">жҡӮж— еҺҶеҸІи®°еҪ•</p>';
                }
            });
        }

        function viewHistoryDetail(id) {
            // жЁЎжӢҹеҺҶеҸІи®°еҪ•иҜҰжғ…еҠҹиғҪ
            alert('еҺҶеҸІи®°еҪ•иҜҰжғ…еҠҹиғҪејҖеҸ‘дёӯ...');
        }

        function generateMarketingCopy() {
            const productName = document.getElementById('marketingProductName').value.trim() || 'е•Ҷе“Ғ';
            const apiKey = document.getElementById('marketingApiKey').value.trim() || 'sk-38404b0c8a7f4272887f66b96192a21e';
            const businessAdvice = document.getElementById('marketingBusinessAdvice').value.trim();
            const positiveReviews = document.getElementById('marketingPositiveReviews').value.trim().split('\n').filter(line => line.trim() !== '');
            
            if (!businessAdvice) {
                alert('иҜ·иҫ“е…Ҙз»ҸиҗҘе»әи®?);
                return;
            }
            if (positiveReviews.length === 0) {
                alert('иҜ·иҫ“е…ҘеҘҪиҜ„еҲ—иЎ?);
                return;
            }
            
            // жҳҫзӨәиҝӣеәҰжқ?            const progressContainer = document.getElementById('marketingProgress');
            const progressFill = document.getElementById('marketingProgressFill');
            const progressMsg = document.getElementById('marketingProgressMsg');
            
            progressContainer.style.display = 'block';
            progressFill.style.width = '30%';
            progressFill.textContent = '30%';
            progressMsg.textContent = 'жӯЈеңЁз”ҹжҲҗиҗҘй”Җж–ҮжЎҲ...';
            
            // и°ғз”Ё API з”ҹжҲҗиҗҘй”Җж–ҮжЎҲ
            fetch('/api/marketing/copy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    product_name: productName,
                    business_advice: businessAdvice,
                    positive_reviews: positiveReviews,
                    api_key: apiKey
                })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    progressFill.style.width = '100%';
                    progressFill.textContent = '100%';
                    progressMsg.textContent = 'з”ҹжҲҗе®ҢжҲҗпј?;
                    
                    // жҳҫзӨәз”ҹжҲҗзҡ„иҗҘй”Җж–ҮжЎҲ
                    document.getElementById('marketingCopyResult').textContent = data.marketing_copy;
                    document.getElementById('marketingResultsSection').style.display = 'block';
                } else {
                    progressMsg.textContent = 'з”ҹжҲҗеӨұиҙҘпј? + (data.error || 'жңӘзҹҘй”ҷиҜҜ');
                    alert('з”ҹжҲҗеӨұиҙҘпј? + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                progressMsg.textContent = 'з”ҹжҲҗеӨұиҙҘпј? + error.message;
                alert('з”ҹжҲҗеӨұиҙҘпј? + error.message);
            });
        }

        // жёІжҹ“жғ…ж„ҹеҲҶеёғйҘјзҠ¶еӣ?        function renderSentimentPieChart(canvasId, labelDistribution) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) {
                console.error('жүҫдёҚеҲ?canvas е…ғзҙ : ' + canvasId);
                return;
            }
            
            // и®ҫзҪ®жҳҺзЎ®зҡ„й«ҳеә?            canvas.height = 400;
            canvas.style.height = '400px';
            
            // еҰӮжһңж—§зҡ„еӣҫиЎЁеӯҳеңЁпјҢе…Ҳй”ҖжҜ?            if (window[canvasId + '_chart']) {
                window[canvasId + '_chart'].destroy();
            }
            
            // й»ҳи®Өзҡ„жғ…ж„ҹеҲҶеёғж•°жҚ?            let negative = 20, neutral = 40, positive = 30;
            
            // е°қиҜ•д»Һдј е…Ҙзҡ„ labelDistribution иҺ·еҸ–ж•°жҚ®
            if (labelDistribution) {
                if (typeof labelDistribution === 'object') {
                    // ж”ҜжҢҒ {'0': x, '1': y, '2': z} ж јејҸ
                    if (labelDistribution['0'] !== undefined) negative = labelDistribution['0'];
                    if (labelDistribution['1'] !== undefined) neutral = labelDistribution['1'];
                    if (labelDistribution['2'] !== undefined) positive = labelDistribution['2'];
                    // д№ҹж”ҜжҢ?{'negative': x, 'neutral': y, 'positive': z} ж јејҸ
                    if (labelDistribution['negative'] !== undefined) negative = labelDistribution['negative'];
                    if (labelDistribution['neutral'] !== undefined) neutral = labelDistribution['neutral'];
                    if (labelDistribution['positive'] !== undefined) positive = labelDistribution['positive'];
                    // иҝҳж”ҜжҢҒеөҢеҘ—з»“жһ?{'negative': {'count': x}, ...}
                    if (labelDistribution['negative'] && typeof labelDistribution['negative'] === 'object' && labelDistribution['negative']['count'] !== undefined) {
                        negative = labelDistribution['negative']['count'];
                    }
                    if (labelDistribution['neutral'] && typeof labelDistribution['neutral'] === 'object' && labelDistribution['neutral']['count'] !== undefined) {
                        neutral = labelDistribution['neutral']['count'];
                    }
                    if (labelDistribution['positive'] && typeof labelDistribution['positive'] === 'object' && labelDistribution['positive']['count'] !== undefined) {
                        positive = labelDistribution['positive']['count'];
                    }
                }
            }
            
            console.log('йҘјзҠ¶еӣҫж•°жҚ?', { negative, neutral, positive });
            
            const ctx = canvas.getContext('2d');
            const chart = new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: ['иҙҹйқў', 'дёӯжҖ?, 'жӯЈйқў'],
                    datasets: [{
                        data: [negative, neutral, positive],
                        backgroundColor: [
                            '#e74c3c',
                            '#f39c12',
                            '#2ecc71'
                        ],
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                font: {
                                    size: 14
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = ((context.raw / total) * 100).toFixed(1);
                                    return context.label + ': ' + context.raw + ' (' + percentage + '%)';
                                }
                            }
                        }
                    }
                }
            });
            
            // дҝқеӯҳеӣҫиЎЁеј•з”Ёд»ҘдҫҝеҗҺз»ӯй”ҖжҜ?            window[canvasId + '_chart'] = chart;
        }

        window.onload = function() {
            checkAuth();
            loadRecentUsers();
            loadProductsForSelect();
        };
    </script>
</body>
</html>
