            })
            .catch(error => {
                console.log('еҠ иҪҪжҷәиғҪеҲҶжһҗжҖ»з»“е’Ңз»ҸиҗҘе»әи®®ж—¶еҸ‘з”ҹй”ҷиҜҜ:', error);
            });

            // жёІжҹ“жғ…ж„ҹеҲҶеёғйҘјзҠ¶еӣ?            renderSentimentPieChart('inputSentimentChart', labelDistribution);
            
            // жӣҙж–°е…¶д»–еӣҫиЎЁ
            const ts = new Date().getTime();
            const performanceChart = document.getElementById('inputPerformanceChart');
            if (performanceChart) {
                performanceChart.src = '/performance?' + ts;
                console.log('жҖ§иғҪжҜ”иҫғеӣҫиЎЁе·Іжӣҙж–?);
            }
            
            const confusionChart = document.getElementById('inputConfusionChart');
            if (confusionChart) {
                confusionChart.src = '/confusion?' + ts;
                console.log('ж··ж·Ҷзҹ©йҳөеӣҫиЎЁе·Іжӣҙж–?);
            }
        }

