                            <div class="label">еҮҶзЎ®зҺ?/div>
                        </div>
                });
                console.log('иҜ„дј°жҢҮж Үе·ІжҳҫзӨ?);
            } else {
                console.error('жүҫдёҚеҲ?inputMetricsDisplay е…ғзҙ ');
            }

            // еҠ иҪҪжҷәиғҪеҲҶжһҗжҖ»з»“е’Ңз»ҸиҗҘе»әи®?            fetch('/api/train/advice')
            .then(r => r.json())
            .then(adviceData => {
                console.log('еҠ иҪҪжҷәиғҪеҲҶжһҗжҖ»з»“е’Ңз»ҸиҗҘе»әи®®з»“жһ?', adviceData);
                if (adviceData.success) {
                    // жҳҫзӨәжҷәиғҪеҲҶжһҗжҖ»з»“
                    const summaryEl = document.getElementById('inputSummary');
                    if (summaryEl) {
                        // зЎ®дҝқжҖ»з»“дёӯдёҚеҢ…еҗ«гҖҗз»ҸиҗҘе»әи®®гҖ?                        let summary = adviceData.summary || 'жҡӮж— еҲҶжһҗжҖ»з»“';
                        summary = summary.replace(/гҖҗз»ҸиҗҘе»әи®®гҖ?g, '');
                        summaryEl.innerHTML = summary;
                    }
                    // жҳҫзӨәз»ҸиҗҘе»әи®®пјҢе°ҶжҚўиЎҢз¬ҰиҪ¬жҚўдёәHTMLж Үзӯҫ
                    const adviceEl = document.getElementById('inputAdvice');
                    if (adviceEl) {
                        let advice = adviceData.advice || 'жҡӮж— з»ҸиҗҘе»әи®®';
                        // е°ҶжҚўиЎҢз¬ҰиҪ¬жҚўдё?<br> ж Үзӯҫ
                        advice = advice.replace(/\n/g, '<br>');
                        adviceEl.innerHTML = advice;
                    }
