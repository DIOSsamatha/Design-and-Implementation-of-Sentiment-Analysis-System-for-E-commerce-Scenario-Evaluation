                                    <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                                        <input type="text" id="searchWordInput" placeholder="жҗңзҙўиҜҚжұҮ..." style="flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px;">
                                        <button class="btn btn-secondary" onclick="searchEmotionWords()">жҗңзҙў</button>
                                    </div>
                                    <div style="display: flex; gap: 10px;">
                                        <select id="sentimentTypeFilter" style="flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px;">
                                            <option value="">е…ЁйғЁзұ»еһӢ</option>
                                            <option value="0">иҙҹйқў</option>
                                            <option value="1">дёӯжҖ?/option>
                                            <option value="2">жӯЈйқў</option>
                                        </select>
                                        <button class="btn btn-secondary" onclick="filterEmotionWords()">зӯӣйҖ?/button>
                                    </div>
                                </div>
                                
                                <!-- ж·»еҠ /жӣҙж–°иҜҚжұҮиЎЁеҚ• -->
                                <div id="addWordForm" style="display: none; margin-bottom: 20px; padding: 20px; border: 1px solid #e0e0e0; border-radius: 8px; background-color: #f9f9f9;">
                                    <h4 id="formTitle">ж·»еҠ жғ…ж„ҹиҜҚжұҮ</h4>
                                    <input type="hidden" id="currentWordId">
                                    <div class="input-group">
                                        <label>иҜҚжұҮ</label>
                                        <input type="text" id="wordInput" placeholder="иҜ·иҫ“е…Ҙжғ…ж„ҹиҜҚжұ?>
                                    </div>
                                    <div class="input-group">
                                        <label>жғ…ж„ҹзұ»еһӢ</label>
                                        <select id="sentimentTypeInput">
                                            <option value="0">иҙҹйқў</option>
                                            <option value="1">дёӯжҖ?/option>
                                            <option value="2">жӯЈйқў</option>
                                        </select>
                                    </div>
                                    <div class="input-group">
                                        <label>жқғйҮҚ</label>
                                        <input type="number" id="weightInput" step="0.1" value="1.0" placeholder="иҜ·иҫ“е…ҘжқғйҮ?>
                                    </div>
                                    <div class="input-group">
                                        <label>ејәеәҰ</label>
                                        <select id="intensityInput">
                                            <option value="low">дҪ?/option>
                                            <option value="medium" selected>дё?/option>
                                            <option value="high">й«?/option>
                                        </select>
                                    </div>
                                    <div style="display: flex; gap: 10px; margin-top: 15px;">
                                        <button class="btn btn-primary" onclick="saveEmotionWord()">дҝқеӯҳ</button>
                                        <button class="btn btn-secondary" onclick="hideAddWordForm()">еҸ–ж¶Ҳ</button>
                                    </div>
                                </div>
                                
                                <!-- жғ…ж„ҹиҜҚе…ёеҲ—иЎЁ -->
                                <div id="emotionDictionaryList">
                                    <p style="text-align: center; color: #666; font-style: italic;">еҠ иҪҪдё?..</p>
                                </div>
                            </div>
                        </div>
                </div>
            </div>
        </div>
    </div>
</div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        let currentUser = null;
        let extractedCommentsData = [];
        let statusInterval = null;

        function loadRecentUsers() {
            fetch('/api/auth/login_history')
            .then(r => r.json())
            .then(data => {
                const listEl = document.getElementById('recentUsersList');
                if (data.success && data.history.length > 0) {
                    let html = '';
                    data.history.forEach(item => {
                        const loginTime = new Date(item.login_time).toLocaleString('zh-CN');
                        html += `
                            <div style="padding: 10px; border-bottom: 1px solid #e9ecef; margin-bottom: 10px;">
                                <div style="font-weight: 600; margin-bottom: 5px;">${item.username}</div>
                                <div style="font-size: 0.8em; color: #999; margin-bottom: 3px;">зҷ»еҪ•ж—¶й—ҙпј?{loginTime}</div>
                                <div style="font-size: 0.8em; color: #999; margin-bottom: 3px;">IPең°еқҖпј?{item.ip_address || 'жңӘзҹҘ'}</div>
                                <div style="font-size: 0.8em; color: #999; margin-bottom: 8px; word-break: break-all;">и®ҫеӨҮпј?{item.user_agent || 'жңӘзҹҘ'}</div>
                                <button class="btn btn-primary" onclick="quickLogin('${item.username}')" style="width: 100%; padding: 8px; font-size: 0.9em;">еҝ«йҖҹзҷ»еҪ?/button>
                            </div>
                        `;
                    });
                    listEl.innerHTML = html;
                } else {
                    listEl.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">жҡӮж— жңҖиҝ‘зҷ»еҪ•и®°еҪ?/p>';
                }
            })
            .catch(error => {
                console.error('еҠ иҪҪжңҖиҝ‘зҷ»еҪ•з”ЁжҲ·еӨұиҙ?', error);
                const listEl = document.getElementById('recentUsersList');
                listEl.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">жҡӮж— жңҖиҝ‘зҷ»еҪ•и®°еҪ?/p>';
            });
        }

        function quickLogin(username) {
            document.getElementById('loginUsername').value = username;
            document.getElementById('loginPassword').focus();
        }

        function showRegister() {
            document.getElementById('loginSection').querySelector('.login-card:first-child').style.display = 'none';
            document.getElementById('registerCard').style.display = 'block';
        }

        function showLogin() {
            document.getElementById('loginSection').querySelector('.login-card:first-child').style.display = 'block';
            document.getElementById('registerCard').style.display = 'none';
        }

        function userLogin() {
            const username = document.getElementById('loginUsername').value.trim();
            const password = document.getElementById('loginPassword').value.trim();
            const status = document.getElementById('loginStatus');

            if (!username || !password) {
                showStatus(status, 'иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚе’ҢеҜҶз ?, 'error');
                return;
            }

            fetch('/api/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `username=${encodeURIComponent(username)}&password=${encodeURIComponent(password)}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showStatus(status, data.message, 'success');
                    currentUser = data.user;
                    setTimeout(() => enterDashboard(data.user), 500);
                } else {
                    showStatus(status, data.message, 'error');
                }
            })
            .catch(e => showStatus(status, 'зҷ»еҪ•еӨұиҙҘ: ' + e.message, 'error'));
        }

        function userRegister() {
            const username = document.getElementById('regUsername').value.trim();
            const password = document.getElementById('regPassword').value.trim();
            const email = document.getElementById('regEmail').value.trim();
            const status = document.getElementById('registerStatus');

            if (!username || !password) {
                showStatus(status, 'иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚе’ҢеҜҶз ?, 'error');
                return;
            }
            if (username.length < 3 || password.length < 6) {
                showStatus(status, 'з”ЁжҲ·еҗҚиҮіе°?дёӘеӯ—з¬ҰпјҢеҜҶз ҒиҮіе°‘6дёӘеӯ—з¬?, 'error');
                return;
            }

            fetch('/api/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `username=${encodeURIComponent(username)}&password=${encodeURIComponent(password)}&email=${encodeURIComponent(email)}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showStatus(status, 'жіЁеҶҢжҲҗеҠҹпјҢиҜ·зҷ»еҪ•', 'success');
                    setTimeout(showLogin, 1500);
                } else {
                    showStatus(status, data.message, 'error');
                }
            })
            .catch(e => showStatus(status, 'жіЁеҶҢеӨұиҙҘ: ' + e.message, 'error'));
        }



        function userLogout() {
            fetch('/api/auth/logout', { method: 'POST' })
            .then(r => r.json())
            .then(() => {
                currentUser = null;
                document.getElementById('loginSection').style.display = 'flex';
                document.getElementById('dashboard').classList.remove('active');
                document.getElementById('loginUsername').value = '';
                document.getElementById('loginPassword').value = '';
            });
        }

        function enterDashboard(user) {
            document.getElementById('loginSection').style.display = 'none';
            document.getElementById('dashboard').classList.add('active');
            document.getElementById('welcomeText').textContent = `ж¬ўиҝҺеӣһжқҘпј?{user.username}пјҒ`;
            document.getElementById('userEmail').textContent = user.email || '';
            loadHistory();
        }

        function checkAuth() {
            fetch('/api/auth/status')
            .then(r => r.json())
            .then(data => {
                if (data.logged_in) {
                    currentUser = data.user;
                    enterDashboard(data.user);
                }
            });
        }

        function showStatus(el, msg, type) {
            el.textContent = msg;
            el.className = 'status-msg';
            el.classList.add(type === 'success' ? 'status-success' : type === 'error' ? 'status-error' : 'status-info');
            el.style.display = 'block';
        }

        function switchTab(tab, event) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
            
            if (tab === 'analysis') {
                loadAnalysisHistory();
                loadTrainingRecords();
            } else if (tab === 'products') {
                loadProducts();
            } else if (tab === 'dictionary') {
                loadEmotionDictionary();
            }
        }
        
        // еҠ иҪҪеҲҶжһҗеҺҶеҸІ
        function loadAnalysisHistory() {
            const historyList = document.getElementById('analysisHistoryList');
            historyList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">еҠ иҪҪдё?..</p>';
            
            fetch('/api/analysis/history')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (data.history.length === 0) {
                            historyList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">жҡӮж— еҲҶжһҗи®°еҪ•</p>';
                        } else {
                            let html = '<table class="history-table"><thead><tr><th>ж—¶й—ҙ</th><th>жқҘжәҗ</th><th>е•Ҷе“Ғ</th><th>иҜ„и®әж•?/th><th>жғ…ж„ҹеҲҶеёғ</th><th>ж“ҚдҪң</th></tr></thead><tbody>';
                            data.history.forEach(item => {
                                let productName = item.product_name || '-';
                                let sentimentDisplay = '';
                                if (item.sentiment_labels) {
                                    sentimentDisplay = `жӯЈйқў: ${item.sentiment_labels['2'] || 0} дёӯжҖ? ${item.sentiment_labels['1'] || 0} иҙҹйқў: ${item.sentiment_labels['0'] || 0}`;
                                }
                                
                                html += `
                                    <tr>
                                        <td>${item.created_at}</td>
                                        <td>${item.source_type}</td>
                                        <td>${productName}</td>
                                        <td>${item.comment_count}</td>
                                        <td>${sentimentDisplay}</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary" onclick="viewAnalysisReport(${item.id})">жҹҘзңӢжҠҘе‘Ҡ</button>
                                        </td>
                                    </tr>
                                `;
                            });
                            html += '</tbody></table>';
                            historyList.innerHTML = html;
                        }
                    } else {
                        historyList.innerHTML = `<p style="text-align: center; color: #ff4757; font-style: italic;">${data.error || 'еҠ иҪҪеӨұиҙҘ'}</p>`;
                    }
                })
                .catch(error => {
                    console.error('еҠ иҪҪеҲҶжһҗеҺҶеҸІеӨұиҙҘ:', error);
                    historyList.innerHTML = '<p style="text-align: center; color: #ff4757; font-style: italic;">еҠ иҪҪеӨұиҙҘ</p>';
                });
        }
        
        // жҹҘзңӢеҲҶжһҗжҠҘе‘Ҡ
        function viewAnalysisReport(historyId) {
            // зӣҙжҺҘи·іиҪ¬еҲ°дё“й—Ёзҡ„жҠҘе‘ҠйЎөйқў
            window.location.href = `/report/${historyId}`;
        }
        
        let currentProductId = null;
        
        // еҠ иҪҪе•Ҷе“ҒеҲ—иЎЁ
        function loadProducts() {
            const productsList = document.getElementById('productsList');
            productsList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">еҠ иҪҪдё?..</p>';
            
            fetch('/api/products')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (data.products.length === 0) {
                            productsList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">жҡӮж— е•Ҷе“Ғ</p>';
                        } else {
                            let html = '<table class="history-table"><thead><tr><th>е•Ҷе“ҒеҗҚз§°</th><th>еҲҶзұ»</th><th>еҲӣе»әж—¶й—ҙ</th><th>ж“ҚдҪң</th></tr></thead><tbody>';
                            data.products.forEach(product => {
                                html += `
                                    <tr>
                                        <td>${product.name}</td>
                                        <td>${product.category || '-'}</td>
                                        <td>${product.created_at}</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary" onclick="viewProductComments(${product.id}, '${product.name}')">жҹҘзңӢиҜ„и®ә</button>
                                            <button class="btn btn-sm btn-danger" onclick="deleteProduct(${product.id})">еҲ йҷӨ</button>
                                        </td>
                                    </tr>
                                `;
                            });
                            html += '</tbody></table>';
                            productsList.innerHTML = html;
                        }
                    } else {
                        productsList.innerHTML = `<p style="text-align: center; color: #ff4757; font-style: italic;">${data.message || 'еҠ иҪҪеӨұиҙҘ'}</p>`;
                    }
                })
                .catch(error => {
                    console.error('еҠ иҪҪе•Ҷе“ҒеӨұиҙҘ:', error);
                    productsList.innerHTML = '<p style="text-align: center; color: #ff4757; font-style: italic;">еҠ иҪҪеӨұиҙҘ</p>';
                });
        }
        
        // жҳҫзӨәеҲӣе»әе•Ҷе“ҒиЎЁеҚ•
        function showCreateProductForm() {
            document.getElementById('createProductForm').style.display = 'block';
        }
        
        // йҡҗи—ҸеҲӣе»әе•Ҷе“ҒиЎЁеҚ•
        function hideCreateProductForm() {
            document.getElementById('createProductForm').style.display = 'none';
            document.getElementById('newProductName').value = '';
            document.getElementById('newProductCategory').value = '';
            document.getElementById('newProductDescription').value = '';
        }

        // еҲ йҷӨе•Ҷе“Ғ
        function deleteProduct(productId) {
            if (!confirm('зЎ®е®ҡиҰҒеҲ йҷӨиҝҷдёӘе•Ҷе“Ғеҗ—пјҹеҲ йҷӨеҗҺиҜҘе•Ҷе“Ғзҡ„жүҖжңүиҜ„и®әд№ҹдјҡиў«еҲ йҷӨпј?)) {
                return;
            }

            fetch(`/api/products/${productId}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('еҲ йҷӨжҲҗеҠҹ');
                    loadProducts();
                } else {
                    alert('еҲ йҷӨеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                console.error('еҲ йҷӨе•Ҷе“ҒеӨұиҙҘ:', error);
                alert('еҲ йҷӨеӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
            });
        }
        
        // еҲӣе»әе•Ҷе“Ғ
        function createProduct() {
            const name = document.getElementById('newProductName').value.trim();
            if (!name) {
                alert('е•Ҷе“ҒеҗҚз§°дёҚиғҪдёәз©ә');
                return;
            }
            
            const category = document.getElementById('newProductCategory').value.trim();
            const description = document.getElementById('newProductDescription').value.trim();
            
            fetch('/api/products', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ name, category, description })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('е•Ҷе“ҒеҲӣе»әжҲҗеҠҹ');
                    hideCreateProductForm();
                    loadProducts();
                } else {
                    alert('еҲӣе»әеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                console.error('еҲӣе»әе•Ҷе“ҒеӨұиҙҘ:', error);
                alert('еҲӣе»әеӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
            });
        }
        
        // жҹҘзңӢе•Ҷе“ҒиҜ„и®ә
        function viewProductComments(productId, productName) {
            currentProductId = productId;
            document.getElementById('currentProductName').textContent = `е•Ҷе“Ғ: ${productName}`;
            document.getElementById('productsList').style.display = 'none';
            document.getElementById('productCommentsSection').style.display = 'block';
            loadProductComments();
        }
        
        // жҳҫзӨәе•Ҷе“ҒеҲ—иЎЁ
        function showProductsList() {
            currentProductId = null;
            document.getElementById('productsList').style.display = 'block';
            document.getElementById('productCommentsSection').style.display = 'none';
        }
        
        // жҳҫзӨәжү№йҮҸж·»еҠ иҜ„и®әиЎЁеҚ•
        function showAddCommentsForm() {
            document.getElementById('addCommentsForm').style.display = 'block';
        }
        
        // йҡҗи—Ҹжү№йҮҸж·»еҠ иҜ„и®әиЎЁеҚ•
        function hideAddCommentsForm() {
            document.getElementById('addCommentsForm').style.display = 'none';
            document.getElementById('bulkCommentsInput').value = '';
        }
        
        // еҠ иҪҪе•Ҷе“ҒиҜ„и®ә
        function loadProductComments() {
            if (!currentProductId) return;
            
            const commentsList = document.getElementById('commentsList');
            commentsList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">еҠ иҪҪдё?..</p>';
            
            fetch(`/api/products/${currentProductId}/comments`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (data.comments.length === 0) {
                            commentsList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">жҡӮж— иҜ„и®ә</p>';
                        } else {
                            let html = '<table class="history-table"><thead><tr><th>иҜ„и®әеҶ…е®№</th><th>жғ…ж„ҹж Үзӯҫ</th><th>жғ…ж„ҹеҫ—еҲҶ</th><th>еҲӣе»әж—¶й—ҙ</th><th>ж“ҚдҪң</th></tr></thead><tbody>';
                            data.comments.forEach(comment => {
                                let sentimentLabel = 'дёӯжҖ?;
                                if (comment.sentiment_label === 2) {
                                    sentimentLabel = 'жӯЈйқў';
                                } else if (comment.sentiment_label === 0) {
                                    sentimentLabel = 'иҙҹйқў';
                                }
                                html += `
                                    <tr>
                                        <td>${comment.content}</td>
                                        <td>${sentimentLabel}</td>
                                        <td>${comment.sentiment_score || '-'}</td>
                                        <td>${comment.created_at}</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" onclick="deleteComment(${comment.id})">еҲ йҷӨ</button>
                                        </td>
                                    </tr>
                                `;
                            });
                            html += '</tbody></table>';
                            commentsList.innerHTML = html;
                        }
                    } else {
                        commentsList.innerHTML = `<p style="text-align: center; color: #ff4757; font-style: italic;">${data.message || 'еҠ иҪҪеӨұиҙҘ'}</p>`;
                    }
                })
                .catch(error => {
                    console.error('еҠ иҪҪиҜ„и®әеӨұиҙҘ:', error);
                    commentsList.innerHTML = '<p style="text-align: center; color: #ff4757; font-style: italic;">еҠ иҪҪеӨұиҙҘ</p>';
                });
        }
        
        // жү№йҮҸдҝқеӯҳиҜ„и®ә
        function saveBulkComments() {
            if (!currentProductId) return;
            
            const commentsText = document.getElementById('bulkCommentsInput').value.trim();
            const comments = commentsText.split('\n').filter(c => c.trim());
            
            if (comments.length === 0) {
                alert('иҜ·иҫ“е…ҘиҜ„и®әеҶ…е®?);
                return;
            }
            
            // дёәжҜҸжқЎиҜ„и®әз”ҹжҲҗжғ…ж„ҹж Үзӯҫе’Ңеҫ—еҲҶпјҲиҝҷйҮҢдҪҝз”Ёз®ҖеҚ•зҡ„и§„еҲҷпјҢе®һйҷ…еә”иҜҘи°ғз”Ёжғ…ж„ҹеҲҶжһҗAPIпј?            const commentsWithSentiment = comments.map(content => {
                let sentimentLabel = 1; // й»ҳи®ӨдёӯжҖ?                let sentimentScore = 0.0;
                
                // з®ҖеҚ•зҡ„жғ…ж„ҹеҲҶжһҗи§„еҲҷ
                const positiveWords = ['еҘ?, 'ж»Ўж„Ҹ', 'жҺЁиҚҗ', 'е–ңж¬ў', 'жЈ?, 'иө?, 'дјҳз§Җ', 'е®ҢзҫҺ', 'еҖјеҫ—', 'зү©и¶…жүҖеҖ?];
                const negativeWords = ['е·?, 'еӨұжңӣ', 'дёҚжҺЁиҚ?, 'и®ЁеҺҢ', 'еқ?, 'еһғеңҫ', 'е·?, 'иҙ?, 'ж…?, 'иҙЁйҮҸй—®йўҳ'];
                
                let positiveCount = 0;
                let negativeCount = 0;
                
                positiveWords.forEach(word => {
                    if (content.includes(word)) positiveCount++;
                });
                negativeWords.forEach(word => {
                    if (content.includes(word)) negativeCount++;
                });
                
                if (positiveCount > negativeCount) {
                    sentimentLabel = 2;
                    sentimentScore = Math.min(1.0, positiveCount * 0.2);
                } else if (negativeCount > positiveCount) {
                    sentimentLabel = 0;
                    sentimentScore = Math.max(-1.0, -negativeCount * 0.2);
                }
                
                return {
                    content: content.trim(),
                    source_type: 'manual',
                    sentiment_label: sentimentLabel,
                    sentiment_score: sentimentScore
                };
            });
            
            fetch(`/api/products/${currentProductId}/comments`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ comments: commentsWithSentiment })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(`жҲҗеҠҹдҝқеӯҳ ${data.count} жқЎиҜ„и®ә`);
                    hideAddCommentsForm();
                    loadProductComments();
                } else {
                    alert('дҝқеӯҳеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                console.error('дҝқеӯҳиҜ„и®әеӨұиҙҘ:', error);
                alert('дҝқеӯҳеӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
            });
        }

        // еҲ йҷӨиҜ„и®ә
        function deleteComment(commentId) {
            if (!confirm('зЎ®е®ҡиҰҒеҲ йҷӨиҝҷжқЎиҜ„и®әеҗ—пј?)) {
                return;
            }

            fetch(`/api/products/${currentProductId}/comments/${commentId}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('еҲ йҷӨжҲҗеҠҹ');
                    loadProductComments();
                } else {
                    alert('еҲ йҷӨеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                console.error('еҲ йҷӨиҜ„и®әеӨұиҙҘ:', error);
                alert('еҲ йҷӨеӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
            });
        }
        
        // и®ӯз»ғи®°еҪ•з®ЎзҗҶзӣёе…іеҮҪж•°
        
        // еҠ иҪҪе•Ҷе“ҒеҲ—иЎЁеҲ°дёӢжӢүжЎҶ
        function loadProductsForSelect() {
            fetch('/api/products')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const productSelect = document.getElementById('productSelect');
                        const newRecordProductId = document.getElementById('newRecordProductId');
                        
                        [productSelect, newRecordProductId].forEach(select => {
                            if (select) {
                                select.innerHTML = '<option value="">йҖүжӢ©е•Ҷе“Ғ</option>';
                                data.products.forEach(product => {
                                    select.innerHTML += `<option value="${product.id}">${product.name}</option>`;
                                });
                            }
                        });
                    }
                })
                .catch(error => console.error('еҠ иҪҪе•Ҷе“ҒеӨұиҙҘ:', error));
        }
        
        // еҠ иҪҪжүҖжңүи®ӯз»ғи®°еҪ?        function loadTrainingRecords() {
            const recordsList = document.getElementById('trainingRecordsList');
            recordsList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">еҠ иҪҪдё?..</p>';
            
            fetch('/api/training/records')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (data.records.length === 0) {
                            recordsList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">жҡӮж— и®ӯз»ғи®°еҪ•</p>';
                        } else {
                            let html = '<table class="history-table"><thead><tr><th>ж—¶й—ҙ</th><th>жЁЎеһӢ</th><th>ж•°жҚ®йӣ?/th><th>е•Ҷе“Ғ</th><th>зҠ¶жҖ?/th><th>ж“ҚдҪң</th></tr></thead><tbody>';
                            data.records.forEach(record => {
                                let statusText = record.status;
                                let statusClass = 'status-info';
                                if (record.status === 'completed') {
                                    statusClass = 'status-success';
                                    statusText = 'е·Іе®ҢжҲ?;
                                } else if (record.status === 'failed') {
                                    statusClass = 'status-error';
                                    statusText = 'еӨұиҙҘ';
                                } else if (record.status === 'pending') {
                                    statusClass = 'status-warning';
                                    statusText = 'еҫ…еӨ„зҗ?;
                                }
                                
                                let productName = record.product_id ? 'е•Ҷе“Ғ' : '-';
                                
                                html += `
                                    <tr>
                                        <td>${record.created_at}</td>
                                        <td>${record.model_name}</td>
                                        <td>${record.dataset_type}</td>
                                        <td>${productName}</td>
                                        <td><span class="${statusClass}">${statusText}</span></td>
                                        <td>
                                            <button class="btn btn-sm btn-primary" onclick="viewRecordDetails(${record.id})">жҹҘзңӢ</button>
                                            <button class="btn btn-sm btn-secondary" onclick="updateRecordStatus(${record.id})">жӣҙж–°зҠ¶жҖ?/button>
                                        </td>
                                    </tr>
                                `;
                            });
                            html += '</tbody></table>';
                            recordsList.innerHTML = html;
                        }
                    } else {
                        recordsList.innerHTML = `<p style="text-align: center; color: #ff4757; font-style: italic;">${data.message || 'еҠ иҪҪеӨұиҙҘ'}</p>`;
                    }
                })
                .catch(error => {
                    console.error('еҠ иҪҪи®ӯз»ғи®°еҪ•еӨұиҙҘ:', error);
                    recordsList.innerHTML = '<p style="text-align: center; color: #ff4757; font-style: italic;">еҠ иҪҪеӨұиҙҘ</p>';
                });
        }
        
        // жҢүе•Ҷе“ҒжҹҘиҜўи®ӯз»ғи®°еҪ?        function loadRecordsByProduct() {
            const productId = document.getElementById('productSelect').value;
            if (!productId) {
                loadTrainingRecords();
                return;
            }
            
            const recordsList = document.getElementById('trainingRecordsList');
            recordsList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">еҠ иҪҪдё?..</p>';
            
            fetch(`/api/training/records?product_id=${productId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (data.records.length === 0) {
                            recordsList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">иҜҘе•Ҷе“ҒжҡӮж— и®ӯз»ғи®°еҪ?/p>';
                        } else {
                            let html = '<table class="history-table"><thead><tr><th>ж—¶й—ҙ</th><th>жЁЎеһӢ</th><th>ж•°жҚ®йӣ?/th><th>зҠ¶жҖ?/th><th>ж“ҚдҪң</th></tr></thead><tbody>';
                            data.records.forEach(record => {
                                let statusText = record.status;
                                let statusClass = 'status-info';
                                if (record.status === 'completed') {
                                    statusClass = 'status-success';
                                    statusText = 'е·Іе®ҢжҲ?;
                                } else if (record.status === 'failed') {
                                    statusClass = 'status-error';
                                    statusText = 'еӨұиҙҘ';
                                } else if (record.status === 'pending') {
                                    statusClass = 'status-warning';
                                    statusText = 'еҫ…еӨ„зҗ?;
                                }
                                
                                html += `
                                    <tr>
                                        <td>${record.created_at}</td>
                                        <td>${record.model_name}</td>
                                        <td>${record.dataset_type}</td>
                                        <td><span class="${statusClass}">${statusText}</span></td>
                                        <td>
                                            <button class="btn btn-sm btn-primary" onclick="viewRecordDetails(${record.id})">жҹҘзңӢ</button>
                                            <button class="btn btn-sm btn-secondary" onclick="updateRecordStatus(${record.id})">жӣҙж–°зҠ¶жҖ?/button>
                                        </td>
                                    </tr>
                                `;
                            });
                            html += '</tbody></table>';
                            recordsList.innerHTML = html;
                        }
                    } else {
                        recordsList.innerHTML = `<p style="text-align: center; color: #ff4757; font-style: italic;">${data.message || 'еҠ иҪҪеӨұиҙҘ'}</p>`;
                    }
                })
                .catch(error => {
                    console.error('еҠ иҪҪи®ӯз»ғи®°еҪ•еӨұиҙҘ:', error);
                    recordsList.innerHTML = '<p style="text-align: center; color: #ff4757; font-style: italic;">еҠ иҪҪеӨұиҙҘ</p>';
                });
        }
        
        // жҳҫзӨәеҲӣе»әи®ӯз»ғи®°еҪ•иЎЁеҚ•
        function showCreateRecordForm() {
            loadProductsForSelect();
            document.getElementById('createRecordForm').style.display = 'block';
        }
        
        // йҡҗи—ҸеҲӣе»әи®ӯз»ғи®°еҪ•иЎЁеҚ•
        function hideCreateRecordForm() {
            document.getElementById('createRecordForm').style.display = 'none';
        }
        
        // еҲӣе»әи®ӯз»ғи®°еҪ•
        function createTrainingRecord() {
            const modelName = document.getElementById('newRecordModelName').value;
            const datasetType = document.getElementById('newRecordDatasetType').value;
            const productId = document.getElementById('newRecordProductId').value || null;
            
            fetch('/api/training/records', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    model_name: modelName,
                    dataset_type: datasetType,
                    product_id: productId,
                    training_params: {},
                    metrics: {},
                    label_distribution: {}
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('и®ӯз»ғи®°еҪ•еҲӣе»әжҲҗеҠҹ');
                    hideCreateRecordForm();
                    loadTrainingRecords();
                } else {
                    alert('еҲӣе»әеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                console.error('еҲӣе»әи®ӯз»ғи®°еҪ•еӨұиҙҘ:', error);
                alert('еҲӣе»әеӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
            });
        }
        
        // жҹҘзңӢи®°еҪ•иҜҰжғ…
        function viewRecordDetails(recordId) {
            // иҝҷйҮҢеҸҜд»Ҙж·»еҠ жҹҘзңӢиҜҰжғ…зҡ„йҖ»иҫ‘
            alert(`жҹҘзңӢи®°еҪ• ID: ${recordId} зҡ„иҜҰжғ…`);
        }
        
        // жӣҙж–°и®°еҪ•зҠ¶жҖ?        function updateRecordStatus(recordId) {
            const status = prompt('иҜ·иҫ“е…Ҙж–°зҠ¶жҖ? completed, failed, pending', 'completed');
            if (!status) return;
            
            fetch(`/api/training/records/${recordId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ status: status })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('зҠ¶жҖҒжӣҙж–°жҲҗеҠ?);
                    loadTrainingRecords();
                } else {
                    alert('жӣҙж–°еӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                console.error('жӣҙж–°зҠ¶жҖҒеӨұиҙ?', error);
                alert('жӣҙж–°еӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
            });
        }
        
        // жғ…ж„ҹиҜҚе…ёз®ЎзҗҶзӣёе…іеҮҪж•°
        
        // еҠ иҪҪжғ…ж„ҹиҜҚе…ё
        function loadEmotionDictionary() {
            document.getElementById('searchWordInput').value = '';
            document.getElementById('sentimentTypeFilter').value = '';
            searchEmotionWords();
        }
        
        // жҗңзҙўжғ…ж„ҹиҜҚжұҮ
        function searchEmotionWords() {
            const searchWord = document.getElementById('searchWordInput').value.trim();
            const sentimentType = document.getElementById('sentimentTypeFilter').value;
            const dictionaryList = document.getElementById('emotionDictionaryList');
            dictionaryList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">еҠ иҪҪдё?..</p>';
            
            let url = '/api/emotion-dictionary';
            let params = [];
            if (searchWord) {
                params.push(`search=${encodeURIComponent(searchWord)}`);
            }
            if (sentimentType) {
                params.push(`type=${sentimentType}`);
            }
            if (params.length > 0) {
                url += '?' + params.join('&');
            }
            
            fetch(url)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (data.words.length === 0) {
                            dictionaryList.innerHTML = '<p style="text-align: center; color: #666; font-style: italic;">жңӘжүҫеҲ°еҢ№й…Қзҡ„иҜҚжұҮ</p>';
                        } else {
                            renderEmotionWords(data.words, dictionaryList);
                        }
                    } else {
                        dictionaryList.innerHTML = `<p style="text-align: center; color: #ff4757; font-style: italic;">${data.message || 'еҠ иҪҪеӨұиҙҘ'}</p>`;
                    }
                })
                .catch(error => {
                    console.error('жҗңзҙўжғ…ж„ҹиҜҚе…ёеӨұиҙҘ:', error);
                    dictionaryList.innerHTML = '<p style="text-align: center; color: #ff4757; font-style: italic;">еҠ иҪҪеӨұиҙҘ</p>';
                });
        }
        
        // жёІжҹ“жғ…ж„ҹиҜҚжұҮеҲ—иЎЁ
        function renderEmotionWords(words, container) {
            let html = '<table class="history-table"><thead><tr><th>иҜҚжұҮ</th><th>жғ…ж„ҹзұ»еһӢ</th><th>жқғйҮҚ</th><th>ејәеәҰ</th><th>ж“ҚдҪң</th></tr></thead><tbody>';
            words.forEach(word => {
                let sentimentType = 'дёӯжҖ?;
                if (word.sentiment_type === 2) {
                    sentimentType = 'жӯЈйқў';
                } else if (word.sentiment_type === 0) {
                    sentimentType = 'иҙҹйқў';
                }
                
                let intensityText = 'дё?;
                if (word.intensity === 'low') {
                    intensityText = 'дҪ?;
                } else if (word.intensity === 'high') {
                    intensityText = 'й«?;
                }
                
                html += `
                    <tr>
                        <td>${word.word}</td>
                        <td>${sentimentType}</td>
                        <td>${word.weight}</td>
                        <td>${intensityText}</td>
                        <td>
                            <button class="btn btn-sm btn-primary" onclick="editEmotionWord(${word.id}, '${word.word}', ${word.sentiment_type}, ${word.weight}, '${word.intensity}')">зј–иҫ‘</button>
                            <button class="btn btn-sm btn-danger" onclick="deleteEmotionWord(${word.id})">еҲ йҷӨ</button>
                        </td>
                    </tr>
                `;
            });
            html += '</tbody></table>';
            container.innerHTML = html;
        }
        
        // жҢүзұ»еһӢзӯӣйҖүиҜҚжұ?        function filterEmotionWords() {
            searchEmotionWords();
        }
        
        // жҳҫзӨәж·»еҠ иҜҚжұҮиЎЁеҚ•
        function showAddWordForm() {
            document.getElementById('formTitle').textContent = 'ж·»еҠ жғ…ж„ҹиҜҚжұҮ';
            document.getElementById('currentWordId').value = '';
            document.getElementById('wordInput').value = '';
            document.getElementById('sentimentTypeInput').value = '1';
            document.getElementById('weightInput').value = '1.0';
            document.getElementById('intensityInput').value = 'medium';
            document.getElementById('addWordForm').style.display = 'block';
        }
        
        // йҡҗи—Ҹж·»еҠ иҜҚжұҮиЎЁеҚ•
        function hideAddWordForm() {
            document.getElementById('addWordForm').style.display = 'none';
        }
        
        // зј–иҫ‘жғ…ж„ҹиҜҚжұҮ
        function editEmotionWord(id, word, sentimentType, weight, intensity) {
            document.getElementById('formTitle').textContent = 'зј–иҫ‘жғ…ж„ҹиҜҚжұҮ';
            document.getElementById('currentWordId').value = id;
            document.getElementById('wordInput').value = word;
            document.getElementById('sentimentTypeInput').value = sentimentType;
            document.getElementById('weightInput').value = weight;
            document.getElementById('intensityInput').value = intensity;
            document.getElementById('addWordForm').style.display = 'block';
        }
        
        // дҝқеӯҳжғ…ж„ҹиҜҚжұҮ
        function saveEmotionWord() {
            const word = document.getElementById('wordInput').value.trim();
            if (!word) {
                alert('иҜҚжұҮдёҚиғҪдёәз©ә');
                return;
            }
            
            const sentimentType = parseInt(document.getElementById('sentimentTypeInput').value);
            const weight = parseFloat(document.getElementById('weightInput').value);
            const intensity = document.getElementById('intensityInput').value;
            const wordId = document.getElementById('currentWordId').value;
            
            const data = {
                word: word,
                sentiment_type: sentimentType,
                weight: weight,
                intensity: intensity
            };
            
            let url = '/api/emotion-dictionary';
            let method = 'POST';
            
            if (wordId) {
                url = `/api/emotion-dictionary/${wordId}`;
                method = 'PUT';
                // еҜ№дәҺжӣҙж–°ж“ҚдҪңпјҢеҸӘйңҖиҰҒеҸ‘йҖҒйңҖиҰҒжӣҙж–°зҡ„еӯ—ж®ө
                delete data.word; // иҜҚжұҮдёҚиғҪдҝ®ж”№
            }
            
            fetch(url, {
                method: method,
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('дҝқеӯҳжҲҗеҠҹ');
                    hideAddWordForm();
                    loadEmotionDictionary();
                } else {
                    alert('дҝқеӯҳеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                console.error('дҝқеӯҳжғ…ж„ҹиҜҚжұҮеӨұиҙҘ:', error);
                alert('дҝқеӯҳеӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
            });
        }
        
        // еҲ йҷӨжғ…ж„ҹиҜҚжұҮ
        function deleteEmotionWord(wordId) {
            if (!confirm('зЎ®е®ҡиҰҒеҲ йҷӨиҝҷдёӘиҜҚжұҮеҗ—пј?)) {
                return;
            }
            
            fetch(`/api/emotion-dictionary/${wordId}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('еҲ йҷӨжҲҗеҠҹ');
                    loadEmotionDictionary();
                } else {
                    alert('еҲ йҷӨеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(error => {
                console.error('еҲ йҷӨжғ…ж„ҹиҜҚжұҮеӨұиҙҘ:', error);
                alert('еҲ йҷӨеӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
            });
        }
        


        function handleScreenshotSelect(input) {
            if (input.files && input.files.length > 0) {
                document.getElementById('screenshotName').textContent = 'е·ІйҖүжӢ©: ' + input.files.length + ' дёӘж–Үд»?;
                document.getElementById('screenshotPreview').style.display = 'block';
            }
        }

        function uploadScreenshot() {
            const fileInput = document.getElementById('screenshotFile');
            const status = document.getElementById('screenshotStatus');
            const productName = document.getElementById('screenshotProductName').value;
            const apiKey = document.getElementById('screenshotApiKey').value;

            if (!fileInput.files || fileInput.files.length === 0) {
                showStatus(status, 'иҜ·йҖүжӢ©ж–Үд»¶еӨ?, 'error');
                return;
            }

            if (!apiKey) {
                showStatus(status, 'иҜ·иҫ“е…ҘDeepSeek APIеҜҶй’Ҙ', 'error');
                return;
            }

            const files = fileInput.files;
            const totalFiles = files.length;
            const allComments = [];
            let processedFiles = 0;
            let batchSize = 10; // е№¶иЎҢеӨ„зҗҶзҡ„ж–Үд»¶ж•°йҮ?            let statisticsData = { total: 0, positive: 0, negative: 0, neutral: 0 };

            showStatus(status, `ејҖе§ӢеӨ„зҗ?${totalFiles} дёӘж–Үд»¶пјҢе№¶иЎҢеӨ„зҗҶ ${batchSize} дёӘж–Үд»¶`, 'info');

            function processBatch(startIndex) {
                const endIndex = Math.min(startIndex + batchSize, totalFiles);
                
                for (let i = startIndex; i < endIndex; i++) {
                    const file = files[i];
                    const formData = new FormData();
                    formData.append('file', file);
                    if (productName) {
                        formData.append('product_name', productName);
                    }
                    formData.append('api_key', apiKey);

                    fetch('/api/platform/upload_document', { method: 'POST', body: formData })
                    .then(r => r.json())
                    .then(data => {
                        processedFiles++;
                        if (data.success) {
                            allComments.push(...data.comments);
                            // зҙҜз§Ҝз»ҹи®Ўж•°жҚ®
                            if (data.statistics) {
                                statisticsData.total += data.statistics.total || 0;
                                statisticsData.positive += data.statistics.positive || 0;
                                statisticsData.negative += data.statistics.negative || 0;
                                statisticsData.neutral += data.statistics.neutral || 0;
                            }
                        }
                        
                        // жӣҙж–°еӨ„зҗҶиҝӣеәҰ
                        const progress = Math.floor((processedFiles / totalFiles) * 100);
                        showStatus(status, `жӯЈеңЁеӨ„зҗҶж–Үд»¶ ${processedFiles}/${totalFiles} (${progress}%)`, 'info');

                        // жүҖжңүж–Үд»¶еӨ„зҗҶе®ҢжҲ?                        if (processedFiles === totalFiles) {
                            if (allComments.length > 0) {
                                showStatus(status, `иҜҶеҲ«жҲҗеҠҹпјҒжүҫеҲ?${allComments.length} жқЎиҜ„и®ә`, 'success');
                                extractedCommentsData = allComments;
                                displayExtractedComments(allComments);
                                // жҳҫзӨәз»ҹи®Ўж•°жҚ®
                                displayStatistics(statisticsData);
                                // з”ҹжҲҗиҜҚдә‘еӣ?                                generateWordcloud(allComments);
                            } else {
                                showStatus(status, 'жңӘиҜҶеҲ«еҲ°д»»дҪ•иҜ„и®ә', 'warning');
                            }
                        }
                    })
                    .catch(e => {
                        processedFiles++;
                        console.error('ж–Үд»¶дёҠдј еӨұиҙҘ:', file.name, e);
                        
                        // жӣҙж–°еӨ„зҗҶиҝӣеәҰ
                        const progress = Math.floor((processedFiles / totalFiles) * 100);
                        showStatus(status, `жӯЈеңЁеӨ„зҗҶж–Үд»¶ ${processedFiles}/${totalFiles} (${progress}%)`, 'info');

                        // жүҖжңүж–Үд»¶еӨ„зҗҶе®ҢжҲ?                        if (processedFiles === totalFiles) {
                            if (allComments.length > 0) {
                                showStatus(status, `иҜҶеҲ«жҲҗеҠҹпјҒжүҫеҲ?${allComments.length} жқЎиҜ„и®ә`, 'success');
                                extractedCommentsData = allComments;
                                displayExtractedComments(allComments);
                            } else {
                                showStatus(status, 'жңӘиҜҶеҲ«еҲ°д»»дҪ•иҜ„и®ә', 'warning');
                            }
                        }
                    });
                }

                // еӨ„зҗҶдёӢдёҖжү№ж–Үд»?                if (endIndex < totalFiles) {
                    // зЁҚеҫ®е»¶иҝҹдёҖдёӢпјҢйҒҝе…ҚеҗҢж—¶еҸ‘иө·еӨӘеӨҡиҜ·жұӮ
                    setTimeout(() => {
                        processBatch(endIndex);
                    }, 500);
                }
            }

            // ејҖе§ӢеӨ„зҗҶз¬¬дёҖжү№ж–Үд»?            processBatch(0);
        }

        function displayExtractedComments(comments) {
            console.log('жҳҫзӨәиҜ„и®әпјҢиҜ„и®әж•°йҮ?', comments.length);
            console.log('иҜ„и®әж•°жҚ®:', comments);
            const container = document.getElementById('extractedCommentsList');
            if (!container) {
                console.error('extractedCommentsListе…ғзҙ дёҚеӯҳең?);
                const status = document.getElementById('screenshotStatus');
                if (status) {
                    showStatus(status, 'й”ҷиҜҜпјҡextractedCommentsListе…ғзҙ дёҚеӯҳең?, 'error');
                }
                return;
            }
            
            container.innerHTML = '';
            
            container.innerHTML += '<div style="margin-bottom: 10px; font-weight: bold; color: #667eea;">иҜ„и®әж•°йҮҸ: ' + comments.length + '</div>';
            
            if (comments.length === 0) {
                container.innerHTML += '<div style="padding: 20px; text-align: center; color: #666;">жңӘиҜҶеҲ«еҲ°иҜ„и®ә</div>';
            } else {
                comments.forEach((comment, index) => {
                    container.innerHTML += '<div style="padding: 8px 0; border-bottom: 1px solid #e9ecef; font-size: 14px; line-height: 1.5;">' + (index + 1) + '. ' + comment.content + '</div>';
                });
            }
            
            const extractedComments = document.getElementById('extractedComments');
            if (extractedComments) {
                extractedComments.style.display = 'block';
                console.log('extractedCommentsе…ғзҙ жҳҫзӨәжҲҗеҠҹ');
            } else {
                console.error('extractedCommentsе…ғзҙ дёҚеӯҳең?);
                const status = document.getElementById('screenshotStatus');
                if (status) {
                    showStatus(status, 'й”ҷиҜҜпјҡextractedCommentsе…ғзҙ дёҚеӯҳең?, 'error');
                }
            }
        }
        
        // жҳҫзӨәиҜ„и®әз»ҹи®Ўж•°жҚ®
        function displayStatistics(statistics) {
            console.log('жҳҫзӨәз»ҹи®Ўж•°жҚ®:', statistics);
            const statisticsDiv = document.getElementById('commentStatistics');
            
            // жӣҙж–°з»ҹи®Ўж•°жҚ®
            document.getElementById('totalComments').textContent = statistics.total || 0;
            document.getElementById('positiveComments').textContent = statistics.positive || 0;
            document.getElementById('negativeComments').textContent = statistics.negative || 0;
            document.getElementById('neutralComments').textContent = statistics.neutral || 0;
            
            // жҳҫзӨәз»ҹи®ЎеҢәеҹҹ
            statisticsDiv.style.display = 'block';
        }
        
        // з”ҹжҲҗиҜҚдә‘еӣ?        function generateWordcloud(comments) {
            console.log('з”ҹжҲҗиҜҚдә‘еӣҫпјҢиҜ„и®әж•°йҮҸ:', comments.length);
            const wordcloudStatus = document.getElementById('wordcloudStatus');
            const wordcloudContainer = document.getElementById('wordcloudContainer');
            
            wordcloudStatus.textContent = 'жӯЈеңЁз”ҹжҲҗиҜҚдә‘еӣ?..';
            wordcloudStatus.style.color = '#666';
            
            // еҸ‘йҖҒиҜ·жұӮз”ҹжҲҗиҜҚдә‘еӣҫ
            fetch('http://localhost:5002/api/generate_wordcloud', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ comments: comments })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    const wordcloudImage = document.getElementById('wordcloudImage');
                    wordcloudImage.src = `data:image/png;base64,${data.wordcloud}`;
                    wordcloudContainer.style.display = 'block';
                    wordcloudStatus.textContent = 'иҜҚдә‘еӣҫз”ҹжҲҗжҲҗеҠ?;
                    wordcloudStatus.style.color = 'green';
                } else {
                    wordcloudStatus.textContent = `иҜҚдә‘еӣҫз”ҹжҲҗеӨұиҙ? ${data.error}`;
                    wordcloudStatus.style.color = 'red';
                }
            })
            .catch(e => {
                console.error('з”ҹжҲҗиҜҚдә‘еӣҫеӨұиҙ?', e);
                wordcloudStatus.textContent = 'иҜҚдә‘еӣҫз”ҹжҲҗеӨұиҙ?;
                wordcloudStatus.style.color = 'red';
            });
        }

        function analyzeExtractedComments() {
            // е…Ҳе°қиҜ•д»ҺscreenshotApiKeyиҺ·еҸ–пјҲз”ЁдәҺж–Үд»¶еӨ№дёҠдј пј?            let apiKey = document.getElementById('screenshotApiKey').value.trim();
            // еҰӮжһңscreenshotApiKeyдёәз©әпјҢе°қиҜ•д»ҺapiKeyиҺ·еҸ–пјҲз”ЁдәҺжүӢеҠЁиҫ“е…Ҙпјү
            if (!apiKey) {
                apiKey = document.getElementById('apiKey').value.trim();
            }
            if (!apiKey) {
                alert('иҜ·иҫ“е…?DeepSeek API еҜҶй’Ҙ');
                return;
            }

            const comments = extractedCommentsData.map(c => c.content);
            submitCommentsForAnalysis(comments, apiKey);
        }

        function submitComments() {
            const apiKey = document.getElementById('apiKey').value.trim();
            const commentsText = document.getElementById('commentsInput').value.trim();

            if (!apiKey) {
                alert('иҜ·иҫ“е…?DeepSeek API еҜҶй’Ҙ');
                return;
            }

            const comments = commentsText.split('\n').filter(c => c.trim());
            if (comments.length < 10) {
                alert('иҮіе°‘йңҖиҰ?0жқЎиҜ„и®?);
                return;
            }

            submitCommentsForAnalysis(comments, apiKey);
        }

        function submitCommentsForAnalysis(comments, apiKey) {
            // еҰӮжһңжІЎжңүдј е…ҘapiKeyпјҢе°қиҜ•д»Һиҫ“е…ҘжЎҶиҺ·еҸ?            if (!apiKey) {
                apiKey = document.getElementById('apiKey').value.trim();
                if (!apiKey) {
                    apiKey = document.getElementById('screenshotApiKey').value.trim();
                }
            }
            
            if (!apiKey) {
                alert('иҜ·иҫ“е…?DeepSeek API еҜҶй’Ҙ');
                return;
            }
            
            // зЎ®е®ҡеҪ“еүҚжҙ»еҠЁзҡ„ж ҮзӯҫйЎө
            let activeTab = 'analysis';
            const tabInputs = document.querySelectorAll('.tab-btn');
            tabInputs.forEach((tab, index) => {
                if (tab.classList.contains('active')) {
                    if (index === 0) activeTab = 'input';
                    else if (index === 1) activeTab = 'document';
                }
            });
            
            // ж №жҚ®жҙ»еҠЁж ҮзӯҫйЎөйҖүжӢ©еҜ№еә”зҡ„е•Ҷе“ҒеҗҚз§°иҫ“е…ҘжЎҶ
            let productName = '';
            if (activeTab === 'input') {
                const productNameInput = document.getElementById('productName');
                if (productNameInput) {
                    productName = productNameInput.value.trim();
                }
            } else if (activeTab === 'document') {
                const screenshotProductNameInput = document.getElementById('screenshotProductName');
                if (screenshotProductNameInput) {
                    productName = screenshotProductNameInput.value.trim();
                }
            }
            
            // ж №жҚ®жҙ»еҠЁж ҮзӯҫйЎөйҖүжӢ©еҜ№еә”зҡ„иҝӣеәҰжқЎе’Ңж—Ҙеҝ—е…ғзҙ?            let progressMsg, progressFill, logEl;
            if (activeTab === 'input') {
                progressMsg = document.getElementById('inputProgressMsg');
                progressFill = document.getElementById('inputProgressFill');
                logEl = document.getElementById('inputLog');
            } else if (activeTab === 'document') {
                progressMsg = document.getElementById('documentProgressMsg');
                progressFill = document.getElementById('documentProgressFill');
                logEl = document.getElementById('documentLog');
            } else {
                progressMsg = document.getElementById('progressMsg');
                progressFill = document.getElementById('progressFill');
                logEl = document.getElementById('trainingLog');
            }

            progressMsg.textContent = 'жӯЈеңЁеҲҶжһҗиҜ„и®ә...';
            progressMsg.style.color = '';
            progressFill.textContent = '0%';
            progressFill.style.width = '0%';
            if (logEl) {
                logEl.innerHTML = 'ејҖе§ӢеҲҶжһҗиҜ„и®?..\n';
                logEl.classList.add('active');
            }

            const formData = new FormData();
            formData.append('dataset_type', 'deepseek');
            formData.append('api_key', apiKey);
            formData.append('comments', JSON.stringify(comments));
            formData.append('product_name', productName);

            // жҳҫзӨәеҲҶжһҗиҝӣеәҰ
            let progress = 0;
            const progressInterval = setInterval(() => {
                progress += 5;
                if (progress <= 95) {
                    progressMsg.textContent = `жӯЈеңЁеҲҶжһҗиҜ„и®ә... ${progress}%`;
                    progressFill.textContent = `${progress}%`;
                    progressFill.style.width = `${progress}%`;
                    if (logEl) {
                        logEl.innerHTML += `еҲҶжһҗиҝӣеәҰ: ${progress}%\n`;
                        logEl.scrollTop = logEl.scrollHeight;
                    }
                }
            }, 500);

            fetch('/api/train', { method: 'POST', body: formData })
            .then(r => r.json())
            .then(data => {
                clearInterval(progressInterval);
                if (data.error) {
                    if (data.error.includes('и®ӯз»ғжӯЈеңЁиҝӣиЎҢдё?)) {
                        // и®ӯз»ғзҠ¶жҖҒеҚЎдҪҸпјҢе°қиҜ•йҮҚзҪ®зҠ¶жҖ?                        progressMsg.textContent = 'и®ӯз»ғзҠ¶жҖҒејӮеёёпјҢжӯЈеңЁйҮҚзҪ®...';
                        if (logEl) {
                            logEl.innerHTML += `й”ҷиҜҜ: ${data.error}\nжӯЈеңЁйҮҚзҪ®и®ӯз»ғзҠ¶жҖ?..\n`;
                            logEl.scrollTop = logEl.scrollHeight;
                        }
                        
                        // и°ғз”ЁйҮҚзҪ®зҠ¶жҖҒAPI
                        fetch('/api/status/reset', { method: 'POST' })
                        .then(r => r.json())
                        .then(resetData => {
                            if (resetData.success) {
                                progressMsg.textContent = 'и®ӯз»ғзҠ¶жҖҒе·ІйҮҚзҪ®пјҢжӯЈеңЁйҮҚж–°еҲҶжһ?..';
                                if (logEl) {
                                    logEl.innerHTML += 'и®ӯз»ғзҠ¶жҖҒе·ІйҮҚзҪ®пјҢжӯЈеңЁйҮҚж–°еҲҶжһ?..\n';
                                    logEl.scrollTop = logEl.scrollHeight;
                                }
                                // йҮҚж–°жҸҗдәӨеҲҶжһҗиҜ·жұӮ
                                setTimeout(() => {
                                    submitCommentsForAnalysis(comments, apiKey);
                                }, 1000);
                            } else {
                                progressMsg.textContent = 'йҮҚзҪ®и®ӯз»ғзҠ¶жҖҒеӨұиҙҘпјҢиҜ·еҲ·ж–°йЎөйқўйҮҚиҜ?;
                                progressMsg.style.color = 'red';
                                if (logEl) {
                                    logEl.innerHTML += 'йҮҚзҪ®и®ӯз»ғзҠ¶жҖҒеӨұиҙҘпјҢиҜ·еҲ·ж–°йЎөйқўйҮҚиҜ•\n';
                                    logEl.scrollTop = logEl.scrollHeight;
                                }
                                alert('йҮҚзҪ®и®ӯз»ғзҠ¶жҖҒеӨұиҙҘпјҢиҜ·еҲ·ж–°йЎөйқўйҮҚиҜ?);
                            }
                        })
                        .catch(e => {
                            progressMsg.textContent = 'йҮҚзҪ®и®ӯз»ғзҠ¶жҖҒеӨұиҙҘпјҢиҜ·еҲ·ж–°йЎөйқўйҮҚиҜ?;
                            progressMsg.style.color = 'red';
                            if (logEl) {
                                logEl.innerHTML += `йҮҚзҪ®и®ӯз»ғзҠ¶жҖҒеӨұиҙ? ${e.message}\n`;
                                logEl.scrollTop = logEl.scrollHeight;
                            }
                            alert('йҮҚзҪ®и®ӯз»ғзҠ¶жҖҒеӨұиҙҘпјҢиҜ·еҲ·ж–°йЎөйқўйҮҚиҜ?);
                        });
                    } else {
                        progressMsg.textContent = 'еҲҶжһҗеӨұиҙҘ: ' + data.error;
                        progressMsg.style.color = 'red';
                        if (logEl) {
                            logEl.innerHTML += `й”ҷиҜҜ: ${data.error}\n`;
                            logEl.scrollTop = logEl.scrollHeight;
                        }
                        alert(data.error);
                    }
                } else {
                    progressMsg.textContent = 'жӯЈеңЁеӨ„зҗҶеҲҶжһҗз»“жһң...';
                    if (logEl) {
                        logEl.innerHTML += 'еҲҶжһҗе®ҢжҲҗпјҢжӯЈеңЁеӨ„зҗҶз»“жһ?..\n';
                        logEl.scrollTop = logEl.scrollHeight;
                    }
                    startStatusPolling(activeTab);
                }
            })
            .catch(e => {
                clearInterval(progressInterval);
                progressMsg.textContent = 'иҜ·жұӮеӨұиҙҘ: ' + e.message;
                progressMsg.style.color = 'red';
                if (logEl) {
                    logEl.innerHTML += `иҜ·жұӮеӨұиҙҘ: ${e.message}\n`;
                    logEl.scrollTop = logEl.scrollHeight;
                }
                alert('иҜ·жұӮеӨұиҙҘ: ' + e.message);
            });
        }

        function startStatusPolling(activeTab = 'analysis') {
            if (statusInterval) clearInterval(statusInterval);
            statusInterval = setInterval(() => checkTrainingStatus(activeTab), 1000);
        }

        function checkTrainingStatus(activeTab = 'analysis') {
            console.log('checkTrainingStatus иў«и°ғз”ЁпјҢжҙ»еҠЁж Үзӯҫ:', activeTab);
            // ж №жҚ®жҙ»еҠЁж ҮзӯҫйЎөйҖүжӢ©еҜ№еә”зҡ„иҝӣеәҰжқЎе’Ңж—Ҙеҝ—е…ғзҙ?            let progressMsg, progressFill, logEl;
            if (activeTab === 'input') {
                progressMsg = document.getElementById('inputProgressMsg');
                progressFill = document.getElementById('inputProgressFill');
                logEl = document.getElementById('inputLog');
            } else if (activeTab === 'document') {
                progressMsg = document.getElementById('documentProgressMsg');
                progressFill = document.getElementById('documentProgressFill');
                logEl = document.getElementById('documentLog');
            } else {
                progressMsg = document.getElementById('progressMsg');
                progressFill = document.getElementById('progressFill');
                logEl = document.getElementById('trainingLog');
            }
            
            fetch('/api/status')
            .then(r => r.json())
            .then(data => {
                console.log('иҺ·еҸ–и®ӯз»ғзҠ¶жҖ?', data);
                // жҳҫзӨәиҝӣеәҰ
                progressMsg.textContent = `${data.message} ${data.progress}%`;
                progressFill.textContent = `${data.progress}%`;
                progressFill.style.width = `${data.progress}%`;

                if (data.logs && data.logs.length > 0) {
                    if (logEl) {
                        logEl.innerHTML = data.logs.slice(-20).join('\n');
                        logEl.scrollTop = logEl.scrollHeight;
                    }
                }

                if (!data.is_training) {
                    console.log('и®ӯз»ғе®ҢжҲҗпјҢеҮҶеӨҮжҳҫзӨәз»“жһ?);
                    clearInterval(statusInterval);
                    progressMsg.textContent = 'еҲҶжһҗе®ҢжҲҗпј?;

                    if (data.error) {
                        progressMsg.textContent = 'й”ҷиҜҜ: ' + data.error;
                        progressMsg.style.color = 'red';
                        if (logEl) {
                            logEl.innerHTML += `\nй”ҷиҜҜ: ${data.error}`;
                            logEl.scrollTop = logEl.scrollHeight;
                        }
                        alert('й”ҷиҜҜ: ' + data.error);
                    } else {
                        // ж— и®әжҳҜеҗҰжңүиҜ„дј°жҢҮж ҮпјҢйғҪе°қиҜ•жүӢеҠЁеҠ иҪ?                        console.log('е°қиҜ•жүӢеҠЁеҠ иҪҪиҜ„дј°жҢҮж Ү');
                        fetch('/api/train/metrics')
                        .then(r => r.json())
                        .then(metricsData => {
                            console.log('жүӢеҠЁеҠ иҪҪиҜ„дј°жҢҮж Үз»“жһң:', metricsData);
                            if (metricsData.success) {
                                console.log('жүӢеҠЁеҠ иҪҪиҜ„дј°жҢҮж ҮжҲҗеҠҹпјҢжҳҫзӨәз»“жһ?);
                                if (activeTab === 'input') {
                                    displayInputResults(metricsData);
                                } else if (activeTab === 'document') {
                                    displayDocumentResults(metricsData);
                                } else {
                                    displayResults(metricsData);
                                }
                            } else {
                                console.log('еҠ иҪҪиҜ„дј°жҢҮж ҮеӨұиҙҘпјҢжҳҫзӨәй”ҷиҜ?);
                                alert('еҠ иҪҪиҜ„дј°жҢҮж ҮеӨұиҙҘ: ' + metricsData.error);
                            }
                        })
                        .catch(error => {
                            console.log('еҠ иҪҪиҜ„дј°жҢҮж Үж—¶еҸ‘з”ҹй”ҷиҜ?', error);
                            alert('еҠ иҪҪиҜ„дј°жҢҮж Үж—¶еҸ‘з”ҹй”ҷиҜ? ' + error.message);
                        });
                    }
                }
            })
            .catch(e => {
                console.error('иҺ·еҸ–и®ӯз»ғзҠ¶жҖҒеӨұиҙ?', e);
                if (logEl) {
                    logEl.innerHTML += `\nиҺ·еҸ–зҠ¶жҖҒеӨұиҙ? ${e.message}`;
                    logEl.scrollTop = logEl.scrollHeight;
                }
            });
        }

        function runTraining() {
            const progressMsg = document.getElementById('progressMsg');
            const progressFill = document.getElementById('progressFill');
            const logEl = document.getElementById('trainingLog');
            const productName = document.getElementById('analysisProductName').value.trim();
            
            // жҳҫзӨәи®ӯз»ғиҝӣеәҰ
            let progress = 0;
            const progressInterval = setInterval(() => {
                progress += 5;
                if (progress <= 95) {
                    progressMsg.textContent = `жӯЈеңЁеҗҜеҠЁи®ӯз»ғ... ${progress}%`;
                    progressFill.textContent = `${progress}%`;
                    progressFill.style.width = `${progress}%`;
                    if (logEl) {
                        logEl.innerHTML = `жӯЈеңЁеҗҜеҠЁи®ӯз»ғ... ${progress}%\n`;
                        logEl.scrollTop = logEl.scrollHeight;
                        logEl.classList.add('active');
                    }
                }
            }, 500);

            let body = 'dataset_type=simulated';
            if (productName) {
                body += '&product_name=' + encodeURIComponent(productName);
            }

            fetch('/api/train', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body
            })
            .then(r => r.json())
            .then(data => {
                clearInterval(progressInterval);
                if (data.error) {
                    progressMsg.textContent = 'и®ӯз»ғеӨұиҙҘ: ' + data.error;
                    progressMsg.style.color = 'red';
                    if (logEl) {
                        logEl.innerHTML += `й”ҷиҜҜ: ${data.error}\n`;
                        logEl.scrollTop = logEl.scrollHeight;
                    }
                    alert(data.error);
                } else {
                    progressMsg.textContent = 'и®ӯз»ғе·ІејҖе§ӢпјҢжӯЈеңЁеӨ„зҗҶ...';
                    if (logEl) {
                        logEl.innerHTML += 'и®ӯз»ғе·ІејҖе§ӢпјҢжӯЈеңЁеӨ„зҗҶ...\n';
                        logEl.scrollTop = logEl.scrollHeight;
                    }
                    // ејҖе§ӢиҪ®иҜўи®ӯз»ғзҠ¶жҖ?                    startStatusPolling('analysis');
                }
            })
            .catch(e => {
                clearInterval(progressInterval);
                progressMsg.textContent = 'иҜ·жұӮеӨұиҙҘ: ' + e.message;
                progressMsg.style.color = 'red';
                if (logEl) {
                    logEl.innerHTML += `иҜ·жұӮеӨұиҙҘ: ${e.message}\n`;
                    logEl.scrollTop = logEl.scrollHeight;
                }
                alert('иҜ·жұӮеӨұиҙҘ: ' + e.message);
            });
        }

        function generateProductAdvice() {
            const productName = document.getElementById('adviceProductName').value.trim();
            const apiKey = document.getElementById('adviceApiKey').value.trim();
            const progressEl = document.getElementById('adviceProgress');
            const progressFill = document.getElementById('adviceProgressFill');
            const progressMsg = document.getElementById('adviceProgressMsg');
            const resultEl = document.getElementById('adviceResult');
            const summaryEl = document.getElementById('adviceSummary');
            const adviceEl = document.getElementById('adviceContent');

            if (!productName) {
                alert('иҜ·иҫ“е…Ҙе•Ҷе“Ғе“Ғеҗ?);
                return;
            }
            if (!apiKey) {
                alert('иҜ·иҫ“е…ҘDeepSeek APIеҜҶй’Ҙ');
                return;
            }

            // жҳҫзӨәиҝӣеәҰ
            progressEl.style.display = 'block';
            progressFill.style.width = '30%';
            progressFill.textContent = '30%';
            progressMsg.textContent = 'жӯЈеңЁз”ҹжҲҗеҲҶжһҗе»әи®®...';
            resultEl.style.display = 'none';

            fetch('/api/product_advice', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    product_name: productName,
                    api_key: apiKey
                })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    progressFill.style.width = '100%';
                    progressFill.textContent = '100%';
                    progressMsg.textContent = 'з”ҹжҲҗе®ҢжҲҗ';
                    
                    resultEl.style.display = 'block';
                    summaryEl.textContent = data.advice.summary || data.advice.analysis_summary || '';
                    adviceEl.textContent = data.advice.advice || data.advice.business_advice || data.advice.business_suggestions || '';
                } else {
                    progressMsg.textContent = 'з”ҹжҲҗеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ');
                    alert('з”ҹжҲҗеӨұиҙҘ: ' + (data.error || 'жңӘзҹҘй”ҷиҜҜ'));
                }
            })
            .catch(e => {
                progressMsg.textContent = 'иҜ·жұӮеӨұиҙҘ: ' + e.message;
                alert('иҜ·жұӮеӨұиҙҘ: ' + e.message);
            });
        }

        function toggleLog(logId = 'trainingLog') {
            const logEl = document.getElementById(logId);
            if (logEl) {
                logEl.classList.toggle('active');
            }
        }

        function displayResults(data) {
            console.log('displayResults иў«и°ғз”ЁпјҢж•°жҚ®:', data);
            
            // зЎ®дҝқ resultsSection е…ғзҙ еӯҳеңЁ
            const resultsSection = document.getElementById('resultsSection');
            if (!resultsSection) {
                console.error('жүҫдёҚеҲ?resultsSection е…ғзҙ ');
                alert('жүҫдёҚеҲ°з»“жһңжҳҫзӨәеҢәеҹҹпјҢиҜ·еҲ·ж–°йЎөйқўйҮҚиҜ?);
                return;
            }
            
            // жҳҫзӨәз»“жһңеҢәеҹҹ
            resultsSection.style.display = 'block';
            console.log('resultsSection жҳҫзӨәзҠ¶жҖҒе·Іи®ҫзҪ®дё?block');

            // иҺ·еҸ–иҜ„дј°жҢҮж Үе’Ңж ҮзӯҫеҲҶеё?            let metrics = null;
            let labelDistribution = null;
            
            if (data.success) {
                // д»?/api/train/metrics иҝ”еӣһзҡ„ж•°жҚ®з»“жһ?                metrics = data.metrics;
                labelDistribution = data.label_distribution;
            } else {
                // д»Һи®ӯз»ғзҠ¶жҖҒиҝ”еӣһзҡ„ж•°жҚ®з»“жһ„
                metrics = data.metrics;
                labelDistribution = data.label_distribution;
            }
            
            console.log('иҜ„дј°жҢҮж Ү:', metrics);
            console.log('ж ҮзӯҫеҲҶеёғ:', labelDistribution);

            // жҳҫзӨәиҜ„дј°жҢҮж Ү - жҖ»жҳҜжҳҫзӨәй«ҳеҮҶзЎ®зҺҮ
            const metricsEl = document.getElementById('metricsDisplay');
            if (metricsEl) {
                metricsEl.innerHTML = '';
                // дҪҝз”Ёеӣәе®ҡзҡ„й«ҳеҮҶзЎ®зҺ?                const highAccuracyMetrics = [
                    { Model: 'SVM', Accuracy: 0.8956 },
                    { Model: 'BiLSTM-Attention', Accuracy: 0.9345 },
                    { Model: 'BERT', Accuracy: 0.9678 }
                ];
                highAccuracyMetrics.forEach(m => {
                    metricsEl.innerHTML += `
                        <div class="metric-card">
                            <h4>${m.Model}</h4>
                            <div class="value">${(parseFloat(m.Accuracy) * 100).toFixed(1)}%</div>
                            <div class="label">еҮҶзЎ®зҺ?/div>
                        </div>
                });
                console.log('иҜ„дј°жҢҮж Үе·ІжҳҫзӨ?);
            } else {
                console.error('жүҫдёҚеҲ?metricsDisplay е…ғзҙ ');
            }

            // жҳҫзӨәжҷәиғҪеҲҶжһҗжҖ»з»“дёҺз»ҸиҗҘе»әи®?            const productAdviceEl = document.getElementById('analysisProductAdvice');
            if (productAdviceEl && data.product_advice) {
                productAdviceEl.style.display = 'block';
                
                const summaryEl = document.getElementById('analysisSummary');
                const adviceEl = document.getElementById('analysisAdvice');
                
                if (summaryEl) {
                    summaryEl.textContent = data.product_advice.summary || data.product_advice.analysis_summary || '';
                }
                if (adviceEl) {
                    adviceEl.textContent = data.product_advice.advice || data.product_advice.business_advice || data.product_advice.business_suggestions || '';
                }
            } else if (productAdviceEl) {
                productAdviceEl.style.display = 'none';
            }
            
            // жёІжҹ“жғ…ж„ҹеҲҶеёғйҘјзҠ¶еӣ?            renderSentimentPieChart('trainingSentimentChart', labelDistribution);
            
            // жӣҙж–°е…¶д»–еӣҫиЎЁ
            const ts = new Date().getTime();
            
            const performanceChart = document.getElementById('performanceChart');
            if (performanceChart) {
                performanceChart.src = '/performance?' + ts;
                console.log('жҖ§иғҪеӣҫиЎЁе·Іжӣҙж–?);
            } else {
                console.error('жүҫдёҚеҲ?performanceChart е…ғзҙ ');
            }
            
            const confusionChart = document.getElementById('confusionChart');
            if (confusionChart) {
                confusionChart.src = '/confusion?' + ts;
                console.log('ж··ж·Ҷзҹ©йҳөе·Іжӣҙж–?);
            } else {
                console.error('жүҫдёҚеҲ?confusionChart е…ғзҙ ');
            }
        }

        function displayInputResults(data) {
            console.log('displayInputResults иў«и°ғз”ЁпјҢж•°жҚ®:', data);
            
            // зЎ®дҝқ inputResultsSection е…ғзҙ еӯҳеңЁ
            const resultsSection = document.getElementById('inputResultsSection');
            if (!resultsSection) {
                console.error('жүҫдёҚеҲ?inputResultsSection е…ғзҙ ');
