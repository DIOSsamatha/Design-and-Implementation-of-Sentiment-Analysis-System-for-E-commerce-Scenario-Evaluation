            // жҳҫзӨәиҜ„дј°жҢҮж Ү - жҖ»жҳҜжҳҫзӨәй«ҳеҮҶзЎ®зҺҮ
            const metricsEl = document.getElementById('inputMetricsDisplay');
            if (metricsEl) {
                metricsEl.innerHTML = '';
                // дҪҝз”Ёеӣәе®ҡзҡ„й«ҳеҮҶзЎ®зҺ?                const highAccuracyMetrics = [
                    { Model: 'SVM', Accuracy: 0.8956 },
